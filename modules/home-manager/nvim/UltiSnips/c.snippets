# Convenience
snippet pf "printf" i
printf("$1", $2);$0
endsnippet

snippet sf "scanf" i
scanf("$1", $2); $0
endsnippet

snippet include "include" b
#include<$1.h>$0
endsnippet

# Loops & Conditions
snippet if "if statement" i
if (${1:bool condition}) {
	$0
}
endsnippet

snippet for "for loop" i
for (int ${1:i} = ${2:0}; $1 ${3:<} ${4:num}; $1${5:++}) {
	$0
}
endsnippet

snippet while "while loop" i
while (${1:bool condition}) {
	$0
}
endsnippet
